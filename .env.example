# Workoflow Skills — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# --- Production Server ---
PROD_SSH_HOST=val-workoflow-prod
PROD_SSH_USER=docker
PROD_DEPLOY_DIR=/home/docker/docker-setups/workoflow-integration-platform
PROD_ORCHESTRATOR_DIR=/home/docker/docker-setups/n8n

# --- Staging Server ---
STAGE_SSH_HOST=val-workoflow-stage
STAGE_SSH_USER=docker
STAGE_DEPLOY_DIR=/home/docker/docker-setups/workoflow-integration-platform
STAGE_ORCHESTRATOR_DIR=/home/docker/docker-setups/n8n

# --- Sentry (Error Tracking) ---
SENTRY_ORG_SLUG=
SENTRY_REGION_URL=
SENTRY_PROJECT_PLATFORM=workoflow
SENTRY_PROJECT_ORCHESTRATOR=workoflow-orchestrator

# --- Default Identifiers ---
DEFAULT_ORG_UUID=
DEFAULT_WORKFLOW_USER_ID=

# --- Platform URL ---
WORKOFLOW_PLATFORM_URL=

# --- Orchestrator (Prompt Executor) ---
ORCHESTRATOR_URL=http://localhost:8080
ORCHESTRATOR_AUTH_TOKEN=

# --- Phoenix (Trace Debugging) ---
PHOENIX_URL=http://localhost:6006

# --- Local Development (check-chrome skill) ---
# Local app URL for manual Chrome reviews, e.g. https://workoflow.ddev.site
LOCAL_APP_URL=
# Test user email appended as ?X-Test-Auth-Email=... for auto-login (dev only)
LOCAL_TEST_AUTH_EMAIL=
